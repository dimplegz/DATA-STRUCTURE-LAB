#include <iostream>
using namespace std;

// Function to perform binary search
int binarySearch(int arr[], int size, int target) {
    int left = 0;
    int right = size - 1;

    while (left <= right) {
        int mid = left + (right - left) / 2;

        // Check if the target is at mid
        if (arr[mid] == target) {
            return mid;  // Return the index of the target
        }

        // If the target is smaller than mid, search in the left half
        if (arr[mid] > target) {
            right = mid - 1;
        }
        // Otherwise, search in the right half
        else {
            left = mid + 1;
        }
    }

    return -1;  // Return -1 if the target is not found
}

int main() {
    int size, target;

    // Ask the user for the size of the array
    cout << "Enter the number of elements in the array: ";
    cin >> size;

    // Declare a sorted array of the given size
    int arr[size];

    // Read array elements from the user (ensure it's sorted)
    cout << "Enter " << size << " sorted elements:" << endl;
    for (int i = 0; i < size; i++) {
        cin >> arr[i];
    }

    // Ask for the element to search
    cout << "Enter the element to search for: ";
    cin >> target;

    // Perform binary search
    int index = binarySearch(arr, size, target);

    // Display the result
    if (index != -1) {
        cout << "Element " << target << " found at index " << index << endl;
    } else {
        cout << "Element " << target << " not found in the array." << endl;
    }

    return 0;
}c
