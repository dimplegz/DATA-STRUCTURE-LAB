#include <iostream>
using namespace std;

// Define a structure for the linked list node
struct Node {
    int data;       // Data part of the node
    Node* next;     // Pointer to the next node
};

int main() {
    int n;

    // Ask the user how many nodes they want in the linked list
    cout << "Enter the number of nodes: ";
    cin >> n;

    // If the user enters a non-positive number, print an error and exit
    if (n <= 0) {
        cout << "The number of nodes must be positive." << endl;
        return 1;  // Exit the program
    }

    Node* head = nullptr; // Start with an empty list
    Node* tail = nullptr; // To keep track of the last node in the list

    // Create the linked list based on user input
    for (int i = 0; i < n; i++) {
        Node* newNode = new Node(); // Dynamically allocate a new node

        // Ask the user for the data of the current node
        cout << "Enter data for node " << i + 1 << ": ";
        cin >> newNode->data;

        // Set the next pointer of the new node to nullptr (last node)
        newNode->next = nullptr;

        // If the list is empty, this is the first node
        if (head == nullptr) {
            head = newNode; // Make the new node the head of the list
            tail = newNode; // The new node is also the tail initially
        } else {
            tail->next = newNode; // Link the new node to the last node
            tail = newNode;       // Update the tail pointer to the new node
        }
    }

    // Print the linked list
    Node* temp = head;  // Start from the head node
    cout << "Linked List: ";
    while (temp != nullptr) {
        cout << temp->data << " ";  // Print the data of the current node
        temp = temp->next;          // Move to the next node
    }
    cout << endl;

    // Free the dynamically allocated memory for each node
    temp = head;
    while (temp != nullptr) {
        Node* toDelete = temp;
        temp = temp->next;
        delete toDelete;  // Delete the current node
    }

    return 0;
}
