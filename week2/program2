#include <iostream>
using namespace std;

int main() {
    int size;

    // Ask the user for the size of the array
    cout << "Enter the number of elements in the array: ";
    cin >> size;

    // Dynamically allocate memory for the array using a pointer
    int* arr = new int[size];

    // Read array elements from the user using pointer arithmetic
    cout << "Enter " << size << " elements:" << endl;
    for(int i = 0; i < size; i++) {
        cin >> *(arr + i);  // Using pointer to access each element
    }

    // Display the array elements using pointer arithmetic
    cout << "The elements of the array are:" << endl;
    for(int i = 0; i < size; i++) {
        cout << *(arr + i) << " ";  // Using pointer to access each element
    }

    cout << endl;

    // Free dynamically allocated memory
    delete[] arr;

    return 0;
}
